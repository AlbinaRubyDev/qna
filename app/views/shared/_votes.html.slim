.voting data-controller = "vote" data-vote-type-value = votable.class.name data-vote-id-value = votable.id
  .vote-rating data-vote-target = "rating"
    = votable.votes.sum(:value)
  - if user_signed_in?
    = link_to "↑", "#", 
      data: { action: "click->vote#vote", value: 1 }
    |  | 
    = link_to "↓", "#",
      data: { action: "click->vote#vote", value: -1 }
